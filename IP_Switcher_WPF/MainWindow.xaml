<Window x:Class="IP_Switcher_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="IP切换器"
        Height="634"
        Width="900"
        MinHeight="530"
        MinWidth="830"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#f8f9fa"
        Loaded="Window_Loaded"
        AllowsTransparency="False" 
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <!-- 窗口淡入动画 - 优化：避免黑色背景闪烁 -->
        <Storyboard x:Key="WindowFadeIn">
            <!-- 使用更柔和的透明度过渡，并确保背景色先加载 -->
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Grid.ColumnSpan="2">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF7B177B" Offset="0"/>
                    <GradientStop Color="#FF9B479B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 应用图标 -->
                <Viewbox Width="32" Height="32">
                    <Grid Width="24" Height="24" RenderTransformOrigin="0.5,0.5">
                        <Path Fill="White" Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z"/>
                    </Grid>
                </Viewbox>
                <TextBlock Text="IP切换器" FontSize="26" FontWeight="Bold" Foreground="White" Effect="{StaticResource TextShadow}"/>
            </StackPanel>
        </Border>

        <!-- 主要内容区域 -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="10" Grid.RowSpan="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 网卡选择区域 -->
            <Border Grid.Row="0" Margin="15,15,15,12" Background="White" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#e0e0e0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Label Content="选择网卡:" VerticalAlignment="Center" FontSize="14" Foreground="#444444" FontWeight="SemiBold" Padding="0,0,10,0"/>
                    <ComboBox Grid.Column="1" Margin="5,0,20,0" 
                              ItemsSource="{Binding NicList}" 
                              SelectedItem="{Binding SelectedNicItem}" 
                              VerticalAlignment="Center" 
                              Height="48" 
                              FontSize="13" 
                              Style="{StaticResource ModernComboBox}">
                        <ComboBox.Resources>
                            <DataTemplate x:Key="NicDisplayTemplate">
                                <DockPanel Margin="0,3" LastChildFill="True">
                                    <Border DockPanel.Dock="Right"
                                            MinWidth="96"
                                            Margin="12,0,0,0"
                                            Padding="10,3"
                                            VerticalAlignment="Center"
                                            Background="#F4F8FC"
                                            BorderBrush="#D7E4F2"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <TextBlock Text="{Binding IPAddress}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#4F6B85"
                                                   HorizontalAlignment="Right"
                                                   TextAlignment="Right"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#2E3338" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding DisplayInfo}" FontSize="10" Foreground="#8A919A" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ComboBox.Resources>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.ItemTemplate>
                            <StaticResource ResourceKey="NicDisplayTemplate"/>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- 当前配置显示框 -->
                    <Border Grid.Column="2" Margin="0,0,0,0" Background="#f8f9fa" CornerRadius="8" Padding="15" HorizontalAlignment="Stretch" Height="132" BorderThickness="1" BorderBrush="#e0e0e0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
                                <TextBlock Text="{Binding CurrentConfigText}" FontSize="13" Foreground="#444444" TextWrapping="Wrap" LineHeight="20"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 配置列表区域 -->
            <Grid Grid.Row="1" Margin="15,0,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 列表标题和操作按钮 -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#e0e0e0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="网络配置:" FontSize="14" FontWeight="SemiBold" Foreground="#444444" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                            <Button Content="➕ 添加" x:Name="addButton" Width="80" Height="36" Background="#3498db" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" Style="{StaticResource ModernButton}" Command="{Binding AddConfigCommand}"/>
                            <Button Content="✏️ 编辑" x:Name="editButton" Width="80" Height="36" Background="#f39c12" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" Style="{StaticResource ModernButton}" Command="{Binding EditConfigCommand}"/>
                            <Button Content="🗑️ 删除" x:Name="deleteButton" Width="80" Height="36" Background="#e74c3c" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Style="{StaticResource ModernButton}" Command="{Binding DeleteConfigCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 配置列表 -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="2" BorderThickness="1" BorderBrush="#e0e0e0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="3" BlurRadius="10" Opacity="0.15"/>
                    </Border.Effect>
                    <ListView x:Name="configListView" BorderThickness="0" Background="White" ItemsSource="{Binding Configs}" SelectedItem="{Binding SelectedConfig}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="#f5f5f5"/>
                                <Setter Property="Foreground" Value="#666666"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="10,8,10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#e0e0e0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                            
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="10,10,10,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#f0f0f0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Foreground" Value="#444444"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f0f8ff"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#e3f2fd"/>
                                        <Setter Property="Foreground" Value="#1976d2"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Resources>
                        
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="配置名称" Width="120" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="IP地址" Width="150" DisplayMemberBinding="{Binding IPAddress}"/>
                                <GridViewColumn Header="子网掩码" Width="150" DisplayMemberBinding="{Binding SubnetMask}"/>
                                <GridViewColumn Header="默认网关" Width="150" DisplayMemberBinding="{Binding DefaultGateway}"/>
                                <GridViewColumn Header="DNS" Width="180" DisplayMemberBinding="{Binding DnsDisplayString}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部按钮区域 -->
        <Border Grid.Row="2" Background="White" BorderThickness="1,1,1,1" BorderBrush="#e0e0e0" Padding="20" Grid.ColumnSpan="2" CornerRadius="0,0,8,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="✓ 应用配置" x:Name="applyButton" Width="120" Height="40" Background="#27ae60" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Margin="0,0,15,0" Style="{StaticResource ModernButton}" Command="{Binding ApplyConfigCommand}"/>
                <Button Content="✕ 退出" x:Name="exitButton" Width="120" Height="40" Background="#95a5a6" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="SemiBold" Style="{StaticResource ModernButton}" Command="{Binding ExitCommand}"/>
            </StackPanel>
        </Border>

        <!-- 加载遮罩层 -->
        <Grid Grid.RowSpan="3" Panel.ZIndex="1000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="12" Padding="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <ContentControl Width="30" Height="30" Margin="0,0,15,0">
                        <ContentControl.RenderTransform>
                            <RotateTransform x:Name="LoadingRotate" CenterX="15" CenterY="15"/>
                        </ContentControl.RenderTransform>
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate>
                                            <Grid>
                                                <Ellipse Width="30" Height="30" Stroke="#3498db" StrokeThickness="3" StrokeDashArray="50,20"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                    <TextBlock Text="{Binding StatusMessage, StringFormat='{}{0}...'}" FontSize="14" Foreground="#444444" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
